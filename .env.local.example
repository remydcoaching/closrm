# Supabase — récupérer dans Supabase > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# Meta / Facebook — App créée sur developers.facebook.com
META_APP_ID=xxx
META_APP_SECRET=xxx
META_WEBHOOK_VERIFY_TOKEN=xxx

# Google Calendar — Console Google Cloud
GOOGLE_CLIENT_ID=xxx
GOOGLE_CLIENT_SECRET=xxx

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=xxx
WHATSAPP_ACCESS_TOKEN=xxx

# AWS SES — IAM user avec policy SES + SNS
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
# Optionnel : nom du Configuration Set SES utilisé pour le tracking événements
SES_CONFIGURATION_SET=closrm-default

# Secret HMAC pour signer les liens "se désinscrire" (sinon SUPABASE_SERVICE_ROLE_KEY est utilisé)
UNSUBSCRIBE_SECRET=xxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
