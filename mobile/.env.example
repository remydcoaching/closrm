# Variables d'environnement Expo (préfixe EXPO_PUBLIC_ = inlinées dans le bundle).
# Copier ce fichier en .env (gitignored) et remplir les valeurs.

# Supabase — mêmes credentials que l'app web (cf .env.local web)
EXPO_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Domaine Vercel pour les écritures via API routes Next.js
EXPO_PUBLIC_API_BASE_URL=https://closrm.fr
